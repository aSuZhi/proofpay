# BNBTask Environment Variables
# Copy this file to .env and fill in your values

# Worker node identity (BSC wallet that receives payment)
WORKER_PRIVATE_KEY=0x_your_worker_private_key_here
WORKER_ADDRESS=0x_your_worker_bsc_address_here

# Client node identity (BSC wallet that sends payment)
CLIENT_PRIVATE_KEY=0x_your_client_private_key_here

# BSCScan API key (optional, for balance queries)
# Get one free at https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here

# BSC RPC endpoint (default: public Binance dataseed)
BSC_RPC=https://bsc-dataseed.binance.org/

# Worker service URL (used by client node)
WORKER_URL=http://localhost:8001
